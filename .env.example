# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=landuse_db
POSTGRES_USER=landuse
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://landuse:changeme_in_production@db:5432/landuse_db

# ─── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
LOG_LEVEL=INFO

# ─── GIS / Raster Settings ────────────────────────────────────────────────────
RASTER_DATA_PATH=/app/data/rasters
OUTPUT_DATA_PATH=/app/data/outputs
MAX_RASTER_SIZE_MB=500
GDAL_CACHEMAX=512

# ─── Storage (S3-compatible, optional) ────────────────────────────────────────
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=landuse-rasters

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
MAPBOX_TOKEN=your_mapbox_token_here

# ─── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Dallas AOI (WGS84) ───────────────────────────────────────────────────────
DALLAS_BBOX_MINX=-97.0
DALLAS_BBOX_MINY=32.6
DALLAS_BBOX_MAXX=-96.5
DALLAS_BBOX_MAXY=33.0
